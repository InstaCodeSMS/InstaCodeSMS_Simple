# 上游 API 配置
UPSTREAM_API_URL=https://api.example.com
UPSTREAM_API_TOKEN=your_upstream_api_token_here

# 验证码 API 域名（可选，默认 https://api.smsapi.cc）
# 用于获取短信验证码，域名可能与 UPSTREAM_API_URL 不同
SMS_API_URL=https://api.smsapi.cc

# Supabase 配置（必需）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Telegram Bot 配置（必需）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# API 基础 URL（必需）
API_BASE_URL=https://your-domain.com

# ========== 支付网关配置 ==========

# BEpusdt 支付配置（可选）
# 注意：BEPUSDT_NOTIFY_URL 必须是公网可访问的地址，BEpusdt 服务器需要能够回调到这个地址
BEPUSDT_API_URL=https://your-bepusdt-instance.com
BEPUSDT_API_TOKEN=your_bepusdt_api_token
BEPUSDT_NOTIFY_URL=https://your-public-domain.com/api/payment/callback

# AliMPay 支付配置（可选）
ALIMPAY_API_URL=https://your-alimpay-instance.com
ALIMPAY_PID=your_alimpay_merchant_id
ALIMPAY_KEY=your_alimpay_merchant_key

# E-pay 支付配置（可选）
EPAY_API_URL=https://your-epay-instance.com
EPAY_PID=your_epay_merchant_id
EPAY_KEY=your_epay_merchant_key
EPAY_SIGN_TYPE=MD5

# Token Pay 支付配置（可选）
TOKENPAY_API_URL=https://your-tokenpay-instance.com
TOKENPAY_MERCHANT_ID=your_tokenpay_merchant_id
TOKENPAY_API_KEY=your_tokenpay_api_key

# PayPal 支付配置（可选）
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Stripe 支付配置（可选）
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# WeChat Pay 支付配置（可选）
WECHATPAY_MERCHANT_ID=your_wechatpay_merchant_id
WECHATPAY_API_V3_KEY=your_wechatpay_api_v3_key
WECHATPAY_PRIVATE_KEY=your_wechatpay_private_key
WECHATPAY_CERTIFICATE=your_wechatpay_certificate

# 价格配置
# 加价倍数，例如 1.2 表示在原价基础上加价 20%
PRICE_MARKUP=1.0

# 日志级别
# 可选值: debug, info, warn, error
LOG_LEVEL=info
